{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "builder|qa",
        "hooks": [
          {
            "type": "command",
            "command": "node ./gates/deploy-test-gate.js"
          }
        ]
      },
      {
        "matcher": "proto-fidelity",
        "hooks": [
          {
            "type": "command",
            "command": "node ./gates/fidelity-gate.js"
          }
        ]
      }
    ]
  }
}
