# Dependencies
node_modules/

# Build / cache
dist/
*.tsbuildinfo
.vitest/

# Generated prototype output (keep the directory, ignore the artifacts)
prototypes/*
!prototypes/.gitkeep

# Per-submission run output from the web intake server
web/.runs/

# Local intake CLI run output (npm run intake -- ... --out live-run-*.json)
live-run-*.json

# Real/confidential client SOWs — never commit. Keep the toy example only.
examples/zennify-sbh/
examples/**/*.real.txt

# Overnight hardening workspace (run logs, failure dumps, journal)
hardening/

# Local env / secrets
.env
.env.local

# OS noise
.DS_Store
